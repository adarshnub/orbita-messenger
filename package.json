{
  "name": "orbita-messenger",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.19.4"
  },
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "backend": "node backend/server.mjs",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "web:build": "expo export --platform web",
    "web:serve": "serve dist --single --listen tcp://0.0.0.0:$PORT",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@expo/vector-icons": "15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "2.105.4",
    "expo": "^54.0.0",
    "expo-audio": "~1.1.1",
    "expo-constants": "~18.0.13",
    "expo-contacts": "~15.0.11",
    "expo-crypto": "~15.0.9",
    "expo-document-picker": "~14.0.8",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "3.0.0",
    "react-native-web": "0.21.2",
    "serve": "^14.2.6",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "eas-cli": "^18.13.0",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  }
}
