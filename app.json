{
  "expo": {
    "name": "Orbita Messenger",
    "slug": "orbita-messenger",
    "scheme": "orbita",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.orbita.messenger",
      "infoPlist": {
        "NSContactsUsageDescription": "Orbita uses contacts to help you find and message people you know.",
        "NSMicrophoneUsageDescription": "Orbita uses the microphone to record and send voice notes.",
        "NSPhotoLibraryUsageDescription": "Orbita uses your photo library so you can attach photos to chats."
      }
    },
    "android": {
      "package": "com.orbita.messenger",
      "googleServicesFile": "./google-services.json",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#E7F4FF"
      },
      "permissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-contacts",
      "expo-image-picker",
      "expo-document-picker",
      "expo-notifications",
      "expo-font",
      "expo-audio",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b3ad437f-4130-4eb6-aa01-d7a40a83e78a"
      }
    },
    "owner": "adarshnub"
  }
}
